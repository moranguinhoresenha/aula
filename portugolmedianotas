programa
{
    funcao inicio()
    {
        real nota1, nota2, nota3, media
        
        // Solicita as três notas
        escreva("Digite a primeira nota: ")
        leia(nota1)
        
        escreva("Digite a segunda nota: ")
        leia(nota2)
        
        escreva("Digite a terceira nota: ")
        leia(nota3)
        
        // Calcula a média
        media = (nota1 + nota2 + nota3) / 3
        
        // Exibe o resultado
        escreva("\nA média das notas é: ", media)
    }
}
